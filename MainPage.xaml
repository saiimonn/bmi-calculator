<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BmiCalculator.MainPage"
             Title="BMI Calculator">

    <ScrollView>
        <VerticalStackLayout Padding="30,40" Spacing="20">

            <!-- Title -->
            <Label Text="BMI Calculator"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="{StaticResource Primary}" />

            <Label Text="Enter your details below"
                   FontSize="14"
                   HorizontalOptions="Center"
                   TextColor="{StaticResource Gray500}" />

            <!-- Input Card -->
            <Border Padding="20"
                    StrokeShape="RoundRectangle 12"
                    Stroke="{StaticResource Gray200}">
                <VerticalStackLayout Spacing="16">

                    <!-- Height Input -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Height (cm)"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Gray600}" />
                        <Border StrokeShape="RoundRectangle 8"
                                Stroke="{StaticResource Gray200}"
                                Padding="12,0">
                            <Entry x:Name="HeightEntry"
                                   Placeholder="e.g. 170"
                                   Keyboard="Numeric"
                                   FontSize="16"
                                   HeightRequest="48" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Weight Input -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Weight (kg)"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Gray600}" />
                        <Border StrokeShape="RoundRectangle 8"
                                Stroke="{StaticResource Gray200}"
                                Padding="12,0">
                            <Entry x:Name="WeightEntry"
                                   Placeholder="e.g. 65"
                                   Keyboard="Numeric"
                                   FontSize="16"
                                   HeightRequest="48" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Calculate Button -->
                    <Button Text="Calculate BMI"
                            Clicked="OnCalculateClicked"
                            FontSize="16"
                            FontAttributes="Bold"
                            HeightRequest="50"
                            CornerRadius="10"
                            Margin="0,4,0,0" />

                </VerticalStackLayout>
            </Border>

            <!-- Result Card -->
            <Border x:Name="ResultCard"
                    Padding="24"
                    StrokeShape="RoundRectangle 12"
                    Stroke="{StaticResource Gray200}"
                    IsVisible="False">
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">

                    <Label Text="Your BMI"
                           FontSize="13"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="{StaticResource Gray500}" />

                    <Label x:Name="BmiValueLabel"
                           FontSize="52"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="{StaticResource Primary}" />

                    <Label x:Name="BmiCategoryLabel"
                           FontSize="20"
                           FontAttributes="Bold"
                           HorizontalOptions="Center" />

                    <BoxView HeightRequest="1"
                             Color="{StaticResource Gray200}"
                             Margin="0,8" />

                    <!-- BMI Scale Reference -->
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="4">
                        <Label Grid.Row="0" Grid.Column="0" Text="Underweight" FontSize="12" TextColor="{StaticResource Gray500}" />
                        <Label Grid.Row="0" Grid.Column="1" Text="&lt; 18.5" FontSize="12" TextColor="{StaticResource Gray500}" HorizontalOptions="End" />

                        <Label Grid.Row="1" Grid.Column="0" Text="Normal" FontSize="12" TextColor="{StaticResource Gray500}" />
                        <Label Grid.Row="1" Grid.Column="1" Text="18.5 – 24.9" FontSize="12" TextColor="{StaticResource Gray500}" HorizontalOptions="End" />

                        <Label Grid.Row="2" Grid.Column="0" Text="Overweight" FontSize="12" TextColor="{StaticResource Gray500}" />
                        <Label Grid.Row="2" Grid.Column="1" Text="25.0 – 29.9" FontSize="12" TextColor="{StaticResource Gray500}" HorizontalOptions="End" />

                        <Label Grid.Row="3" Grid.Column="0" Text="Obese" FontSize="12" TextColor="{StaticResource Gray500}" />
                        <Label Grid.Row="3" Grid.Column="1" Text="≥ 30.0" FontSize="12" TextColor="{StaticResource Gray500}" HorizontalOptions="End" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
